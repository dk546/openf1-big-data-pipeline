# Internal project planning markdown (keep locally for Cursor; do not publish)
/*.md
!/README.md

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
ENV/
env/

# Environment and secrets
.env
.env.*
!.env.example

# Jupyter
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs and temp
*.log
logs/
tmp/
temp/
artifacts/pipeline_logs/*.log

# Large data (keep folder structure via .gitkeep)
data/bronze/**/*
!data/bronze/.gitkeep
data/silver/**/*
!data/silver/.gitkeep
data/gold/**/*
!data/gold/.gitkeep
*.parquet
*.jsonl
data/**/*.json
data/**/*.csv

# Evidence snapshots: ignore raw/processed data layers (Bronze JSONL, Silver/Gold Parquet,
# Spark markers like _SUCCESS and *.crc). The lightweight reports under
# evidence/<run>/reports/data_quality/ and manifests / feature definitions under
# evidence/<run>/artifacts/ stay tracked.
evidence/*/data/bronze/
evidence/*/data/silver/
evidence/*/data/gold/

# Large model binaries (allow small exports in reports/)
models/
*.pkl
*.pickle
*.h5
*.pt
*.onnx

# Spark
spark-warehouse/
metastore_db/
derby.log

# Colab / local scratch
/content/tmp/
.sample_data/

# Editable install / build (Colab and local)
*.egg-info/
.eggs/
pip-wheel-metadata/

# Optional: ignore very large figures (keep report CSVs and small PNGs)
# reports/figures/*.html

# Internal dev audit logs (Markdown only — keep code-emitted CSVs under artifacts/)
artifacts/pipeline_logs/*.md

# Internal report drafts and methodology (working documents — not public)
reports/report_draft/

# Evidence-freeze checklists (internal QA tooling)
evidence/**/EVIDENCE_FREEZE_CHECKLIST.md

# Cursor IDE local settings (defensive)
.cursor/
